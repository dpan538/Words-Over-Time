iles west of Cernauti Reinforcements and supplies were pouring into the Russian lines all along the front and it was believed the lull would be brief The siege of Sevastopol at the south western tip of the Crimea entered its seventh day with no new reports of progress Thirtyfive German planes were destroyed yesterday in the Se vastopol area by Soviet aircraft and antiaircraft gunners Store Hours 930 to 600 Thursday 1230 to 900 PkilipXorn _ 11 Street I Between FG"], "digitized": true, "extract_timestamp": "2025-04-13T08:09:24.005Z", "group": ["ndnp/dlc-2020_now", "library-of-congress-washington-dc-awardee-8"], "hassegments": false, "id": "http://www.loc.gov/resource/sn82016181/1944-04-24/ed-1/?sp=6", "image_url": ["https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_depoorter_ver01:data:sn82016181:00516999998:1944042401:1769/full/pct:6.25/0/default.jpg#h=300&w=230", "https://tile.loc.gov/image-services/iiif/service:ndnp:dlc:batch_dlc_depoorter_ver01:data:sn82016181:00516999998:1944042401:1769/full/pct:12.5/0/default.jpg#h=600&w=461", "https://tile.loc.gov/text-services/word-coordinates-service?segment=/service/ndnp/dlc/batch_dlc_depoorter_ver01/data/sn82016181/00516999998/1944042401/1769.xml&format=alto_xml"], "index": 1, "language": ["english"], "location": ["district of columbia", "washington d.c.", "united states", "washington"], "location_city": ["washington"], "location_country": ["united states"], "location_state": ["district of columbia"], "mime_type": ["image/jp2", "application/pdf", "text/xml", "image/jpeg", "image/jpeg", "application/json", "text/plain"], "number": ["1", "9", "6", "sn82016181", "5", "0", "8", "0000000006"], "number_edition": ["1"], "number_lccn": ["sn82016181"], "number_page": ["0000000006"], "number_reel": ["0", "0", "5", "1", "6", "9", "9", "9", "9", "9", "8"], "online_format": ["image", "pdf", "online text"], "original_format": ["newspaper"], "page_id": "sn82016181-1944-04-24-ed-1-1769", "partof": ["the washington daily n